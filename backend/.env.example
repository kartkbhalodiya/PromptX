# Required: Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Groq fallback model (https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Client API key authentication (leave empty to disable)
CLIENT_API_KEY=

# Django settings
DJANGO_SECRET_KEY=promptx-dev-secret-key
DEBUG=True

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_OAUTH2_CLIENT_ID=your_google_client_id_here
GOOGLE_OAUTH2_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_OAUTH2_REDIRECT_URI=http://127.0.0.1:8000/auth/complete/google-oauth2/

