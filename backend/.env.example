# Required: Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Groq fallback model (https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Client API key authentication (leave empty to disable)
CLIENT_API_KEY=

# Django settings
DJANGO_SECRET_KEY=your_django_secret_key_here
DEBUG=True

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_OAUTH2_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_OAUTH2_CLIENT_SECRET=your_google_oauth_client_secret_here
GOOGLE_OAUTH2_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback/

# Razorpay Payment (https://dashboard.razorpay.com/)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Resend Email API (https://resend.com/)
RESEND_API_KEY=your_resend_api_key_here

# NVIDIA Models
NVIDIA_API_KEY=your_nvidia_api_key_here
