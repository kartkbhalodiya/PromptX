# Example environment configuration
# Copy this file to .env and add your API keys

# Primary AI Model (Required - at least one key needed)
GEMINI_API_KEY=your_gemini_api_key_here

# Fallback Models (Optional - for automatic switching when primary fails)
NVIDIA_MISTRAL_API_KEY=your_nvidia_mistral_api_key_here
NVIDIA_QWEN_API_KEY=your_nvidia_qwen_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Server Configuration
PORT=5000
CLIENT_API_KEY=optional_custom_api_key_to_protect_your_backend

# Get your free API keys:
# Gemini: https://ai.google.dev/
# NVIDIA NIM (Mistral): https://build.nvidia.com/
# NVIDIA NIM (Qwen): https://build.nvidia.com/
# HuggingFace: https://huggingface.co/settings/tokens
